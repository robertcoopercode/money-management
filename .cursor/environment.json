{
  "install": "pnpm install && pnpm db:generate && pnpm db:migrate && pnpm db:seed",
  "start": "sudo service postgresql start",
  "terminals": [
    {
      "name": "API Server",
      "command": "pnpm dev:api"
    },
    {
      "name": "Web Dev Server",
      "command": "pnpm dev:web"
    }
  ]
}

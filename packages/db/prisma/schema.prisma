generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CASH
  CREDIT
  INVESTMENT
  LOAN
}

enum LoanType {
  MORTGAGE
  AUTO
  LINE_OF_CREDIT
}

enum OriginType {
  MANUAL
  CSV_IMPORT
}

enum ImportBatchStatus {
  PENDING
  PROCESSED
  FAILED
}

enum ImportRowAction {
  MERGED
  CREATED
  SKIPPED
}

enum ClearingStatus {
  UNCLEARED
  CLEARED
  RECONCILED
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Account {
  id                  String        @id @default(cuid())
  name                String
  type                AccountType
  startingBalanceMinor Int          @default(0)
  startingBalanceAt   DateTime     @default(now())
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  transactions        Transaction[]
  incomingTransferLinks Transaction[] @relation("TransferTarget")
  importBatches       ImportBatch[]
  loanProfile         LoanProfile?
}

model LoanProfile {
  id                   String    @id @default(cuid())
  accountId            String    @unique
  loanType             LoanType
  interestRateAnnual   Decimal   @db.Decimal(8, 6)
  minimumPaymentMinor  Int
  defaultCategoryId    String?
  account              Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  defaultCategory      Category? @relation("LoanProfileDefaultCategory", fields: [defaultCategoryId], references: [id], onDelete: SetNull)
}

model Payee {
  id                String         @id @default(cuid())
  name              String
  normalizedName    String
  isArchived        Boolean        @default(false)
  defaultCategoryId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  transactions      Transaction[]
  transactionSplits TransactionSplit[]
  defaultCategory   Category?      @relation("PayeeDefaultCategory", fields: [defaultCategoryId], references: [id], onDelete: SetNull)

  @@index([normalizedName])
}

model CategoryGroup {
  id         String     @id @default(cuid())
  name       String
  sortOrder  String     @default("a0")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  categories Category[]

  @@unique([name])
}

model Category {
  id               String               @id @default(cuid())
  name             String               @unique
  groupId          String?
  isIncomeCategory Boolean              @default(false)
  isArchived       Boolean              @default(false)
  sortOrder        String               @default("a0")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  assignments      CategoryAssignment[]
  group            CategoryGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  transactions      Transaction[]
  transactionSplits TransactionSplit[]
  payeesWithDefault Payee[]            @relation("PayeeDefaultCategory")
  loanProfilesWithDefault LoanProfile[] @relation("LoanProfileDefaultCategory")
}

model Transaction {
  id                    String              @id @default(cuid())
  accountId             String
  date                  DateTime
  amountMinor           Int
  payeeId               String?
  categoryId            String?
  note                  String?
  clearingStatus        ClearingStatus      @default(UNCLEARED)
  manualCreated         Boolean             @default(true)
  importLinked          Boolean             @default(false)
  pendingApproval       Boolean             @default(false)
  importedTransactionId String?             @unique
  isTransfer            Boolean             @default(false)
  transferAccountId     String?
  transferPairId        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  account               Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category              Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  payee                 Payee?              @relation(fields: [payeeId], references: [id], onDelete: SetNull)
  transferAccount       Account?            @relation("TransferTarget", fields: [transferAccountId], references: [id], onDelete: SetNull)
  importedTransaction   ImportedTransaction? @relation("ImportLink", fields: [importedTransactionId], references: [id], onDelete: SetNull)
  origins               TransactionOrigin[]
  splits                TransactionSplit[]
  tags                  TransactionTag[]
  matchedImportRows     ImportRowMatch[]    @relation("MatchedTransaction")

  @@index([accountId, date])
  @@index([accountId, clearingStatus, date])
  @@index([isTransfer, date])
  @@index([categoryId, date])
  @@index([amountMinor, date])
  @@index([transferPairId])
}

model TransactionOrigin {
  id              String       @id @default(cuid())
  transactionId   String
  originType      OriginType
  importBatchId   String?
  rawReference    String?
  rawPayload      Json?
  createdAt       DateTime     @default(now())
  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  transaction     Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([originType, importBatchId])
  @@unique([transactionId, originType, importBatchId])
}

model ImportBatch {
  id                   String              @id @default(cuid())
  accountId            String
  uploadedAt           DateTime            @default(now())
  fileName             String
  status               ImportBatchStatus   @default(PENDING)
  rowsTotal            Int                 @default(0)
  rowsMatched          Int                 @default(0)
  rowsCreated          Int                 @default(0)
  rowsSkipped          Int                 @default(0)
  account              Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  matches              ImportRowMatch[]
  origins              TransactionOrigin[]
  importedTransactions ImportedTransaction[]
}

model ImportedTransaction {
  id            String       @id @default(cuid())
  importBatchId String
  rowIndex      Int
  date          DateTime
  amountMinor   Int
  payeeName     String
  note          String?
  rawPayload    Json
  createdAt     DateTime     @default(now())

  importBatch   ImportBatch  @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation("ImportLink")

  @@unique([importBatchId, rowIndex])
  @@index([date, amountMinor])
}

model ImportRowMatch {
  id                   String          @id @default(cuid())
  importBatchId        String
  rowIndex             Int
  matchedTransactionId String?
  matchScore           Float?
  matchReason          String?
  action               ImportRowAction
  createdAt            DateTime        @default(now())
  importBatch          ImportBatch     @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  matchedTransaction   Transaction?    @relation("MatchedTransaction", fields: [matchedTransactionId], references: [id], onDelete: SetNull)

  @@index([importBatchId, rowIndex])
}

model CategoryAssignment {
  id            String     @id @default(cuid())
  month         String
  categoryId    String
  assignedMinor Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  category      Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([month, categoryId])
  @@index([categoryId, month])
}

model Tag {
  id              String           @id @default(cuid())
  name            String
  normalizedName  String           @unique
  description     String?
  backgroundColor String           @default("#374151")
  textColor       String           @default("#FFFFFF")
  isArchived      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  transactions    TransactionTag[]
  splits          SplitTag[]
}

model TransactionTag {
  id            String      @id @default(cuid())
  transactionId String
  tagId         String
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([transactionId, tagId])
  @@index([tagId])
}

model TransactionSplit {
  id            String         @id @default(cuid())
  transactionId String
  categoryId    String
  payeeId       String?
  note          String?
  amountMinor   Int
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  transaction   Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  payee         Payee?         @relation(fields: [payeeId], references: [id], onDelete: SetNull)
  tags          SplitTag[]

  @@index([transactionId])
  @@index([categoryId, transactionId])
}

model SplitTag {
  id      String           @id @default(cuid())
  splitId String
  tagId   String
  split   TransactionSplit @relation(fields: [splitId], references: [id], onDelete: Cascade)
  tag     Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([splitId, tagId])
  @@index([tagId])
}

